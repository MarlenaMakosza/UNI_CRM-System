{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --watch backend/src/main.ts",
    "seed": "deno run --allow-net --allow-env db/seed.ts",
    "lint": "deno lint",
    "lint:fix": "deno lint --fix"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "oak": "https://deno.land/x/oak@v12.6.0/mod.ts",
    "oakCors": "https://deno.land/x/cors@v1.2.2/mod.ts",
    "db": "./db/db.ts",
    "mod": "https://deno.land/std@0.208.0/path/mod.ts",
    "bcrypt": "https://deno.land/x/bcrypt@v0.4.1/mod.ts",
    "jose": "npm:jose@5.9.6"
  },
  "compilerOptions": {
    "strict": true
  },
  "lint": {
    "include": [
      "backend/src"
    ]
  }
